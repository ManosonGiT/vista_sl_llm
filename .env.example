# VISTA-SL LLM Backend Configuration Example

# --- LLM Providers (LiteLLM/Universal Format) ---
# Select the provider and model you wish to use (e.g., groq, openai, together_ai)
# Format: [provider]/[model_name]
LLM_MODEL=groq/llama-3.1-8b-instant

# --- LLM Provider API Keys ---
# Provide the key corresponding to the LLM provider selected above
GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here
# TOGETHERAI_API_KEY=your_togetherai_api_key_here

# --- Backup LLM Provider (Optional fallback on error/rate limit) ---
# Format: [provider]/[model_name] (e.g., openai/llama3)
# BACKUP_LLM_MODEL=your_backup_model
# BACKUP_LLM_API_KEY=your_backup_api_key_here
# BACKUP_LLM_API_BASE=http://host.docker.internal:11434/v1


# --- Database Configuration ---
# Local execution database URL (pointing to localhost)
DATABASE_URL=postgresql://lionakis:TempPass@localhost:5432/vista_db

# Database credentials used by Docker Compose to provision the database service
DB_USER=lionakis
DB_PASS=TempPass
DB_NAME=vista_db

# --- Platform Integration ---
# Base URL for fetching user progress stats
PLATFORM_URL=https://vistasl.eelvex.net
# Shared secret key used for signing user progress fetch requests
COACH_SECRET_KEY=your_shared_coach_secret_here


# --- Exposed Network Ports ---
BACKEND_PORT=8000
DB_PORT=5432

# --- Rate Limiting Configuration ---
# Maximum number of requests allowed in the window (default: 10)
RATE_LIMIT_REQUESTS=10
# Time window in seconds (default: 60)
RATE_LIMIT_WINDOW=60
